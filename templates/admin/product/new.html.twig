{% extends 'base.html.twig' %}

{% block title %}Nouveau Produit - MODUSCAP{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="{{ path('admin_product_index') }}">Produits</a>
                    </li>
                    <li class="breadcrumb-item active">Nouveau</li>
                </ol>
            </nav>
            <h1 class="h3 mb-1">Créer un Nouveau Produit</h1>
            <p class="text-muted">Ajoutez un nouveau produit à votre catalogue MODUSCAP</p>
        </div>
    </div>

    {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': true}}) }}
    
    <div class="row">
        <div class="col-lg-8">
            <!-- Informations générales -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-info-circle me-2"></i>Informations Générales
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            {{ form_row(form.code, {
                                'attr': {'class': 'form-control form-control-lg', 'placeholder': 'Ex: MODUS001'},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.category, {
                                'attr': {'class': 'form-select'},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            {{ form_row(form.basePrice, {
                                'attr': {'class': 'form-control', 'placeholder': '0.00'},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.surface, {
                                'attr': {'class': 'form-control', 'placeholder': 'Ex: 25.5'},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            {{ form_row(form.dimensions, {
                                'attr': {'class': 'form-control', 'placeholder': 'Ex: 6m × 4,7m × 2,8m'},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.rooms, {
                                'attr': {'class': 'form-control', 'placeholder': 'Ex: 3'},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            {{ form_row(form.height, {
                                'attr': {'class': 'form-control', 'placeholder': 'Ex: 280'},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.assemblyTime, {
                                'attr': {'class': 'form-control', 'placeholder': 'Ex: 5'},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Spécifications techniques -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-cogs me-2"></i>Spécifications Techniques
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            {{ form_row(form.materials, {
                                'attr': {'class': 'form-control', 'rows': 3, 'placeholder': 'Liste des matériaux utilisés...'},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.equipment, {
                                'attr': {'class': 'form-control', 'rows': 3, 'placeholder': 'Équipements inclus...'},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-12">
                            {{ form_row(form.specifications, {
                                'attr': {'class': 'form-control', 'rows': 3, 'placeholder': 'Spécifications techniques détaillées...'},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-12">
                            {{ form_row(form.advantages, {
                                'attr': {'class': 'form-control', 'rows': 3, 'placeholder': 'Principaux avantages du produit...'},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Traductions multilingues -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-globe me-2"></i>Contenu Multilingue
                        <small class="text-muted">Saisissez le contenu dans toutes les langues actives</small>
                    </h5>
                </div>
                <div class="card-body">
                    <!-- Onglets des langues -->
                    <ul class="nav nav-tabs" id="languageTabs" role="tablist">
                        {% for translation in product.translations %}
                            {% set language = translation.language %}
                            <li class="nav-item" role="presentation">
                                <button class="nav-link {{ loop.first ? 'active' : '' }}" 
                                        id="lang-{{ language.code }}-tab" 
                                        data-bs-toggle="tab" 
                                        data-bs-target="#lang-{{ language.code }}" 
                                        type="button" role="tab">
                                    <img src="/assets/flags/{{ language.code }}.svg" 
                                         alt="{{ language.name }}" 
                                         width="20" height="15" 
                                         class="me-2 rounded">
                                    {{ language.name }}
                                    {% if not language.active %}
                                        <span class="badge bg-warning text-dark ms-1">Inactif</span>
                                    {% endif %}
                                </button>
                            </li>
                        {% endfor %}
                    </ul>
                    
                    <!-- Contenu des onglets -->
                    <div class="tab-content mt-3" id="languageTabsContent">
                        {% for translation in product.translations %}
                            {% set language = translation.language %}
                            <div class="tab-pane fade {{ loop.first ? 'show active' : '' }}" 
                                 id="lang-{{ language.code }}" 
                                 role="tabpanel">
                                
                                <div class="row">
                                    <div class="col-12 mb-3">
                                        <label class="form-label fw-bold">Nom du produit</label>
                                        <input type="text" 
                                               class="form-control form-control-lg" 
                                               name="product[translations][{{ loop.index0 }}][name]" 
                                               value="{{ translation.name }}"
                                               placeholder="Nom du produit en {{ language.name }}"
                                               {{ not language.active ? 'disabled' : '' }}>
                                        <div class="form-text">
                                            Nom qui apparaîtra sur le site pour {{ language.name }}
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="row">
                                    <div class="col-12 mb-3">
                                        <label class="form-label fw-bold">Description courte</label>
                                        <input type="text" 
                                               class="form-control" 
                                               name="product[translations][{{ loop.index0 }}][shortDescription]" 
                                               value="{{ translation.shortDescription }}"
                                               placeholder="Résumé en une phrase (optionnel)"
                                               {{ not language.active ? 'disabled' : '' }}>
                                        <div class="form-text">
                                            Description courte pour les aperçus et listes
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="row">
                                    <div class="col-12 mb-3">
                                        <label class="form-label fw-bold">Description complète</label>
                                        <textarea class="form-control" 
                                                  name="product[translations][{{ loop.index0 }}][description]" 
                                                  rows="5"
                                                  placeholder="Description détaillée du produit en {{ language.name }}"
                                                  {{ not language.active ? 'disabled' : '' }}>{{ translation.description }}</textarea>
                                        <div class="form-text">
                                            Description complète du produit
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">Concept & Design</label>
                                        <textarea class="form-control" 
                                                  name="product[translations][{{ loop.index0 }}][concept]" 
                                                  rows="3"
                                                  placeholder="Concept et aspects design..."
                                                  {{ not language.active ? 'disabled' : '' }}>{{ translation.concept }}</textarea>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">Matériaux détaillés</label>
                                        <textarea class="form-control" 
                                                  name="product[translations][{{ loop.index0 }}][materialsDetail]" 
                                                  rows="3"
                                                  placeholder="Détails sur les matériaux..."
                                                  {{ not language.active ? 'disabled' : '' }}>{{ translation.materialsDetail }}</textarea>
                                    </div>
                                </div>
                                
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">Équipements détaillés</label>
                                        <textarea class="form-control" 
                                                  name="product[translations][{{ loop.index0 }}][equipmentDetail]" 
                                                  rows="3"
                                                  placeholder="Liste détaillée des équipements..."
                                                  {{ not language.active ? 'disabled' : '' }}>{{ translation.equipmentDetail }}</textarea>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">Performances</label>
                                        <textarea class="form-control" 
                                                  name="product[translations][{{ loop.index0 }}][performanceDetails]" 
                                                  rows="3"
                                                  placeholder="Spécifications techniques et performances..."
                                                  {{ not language.active ? 'disabled' : '' }}>{{ translation.performanceDetails }}</textarea>
                                    </div>
                                </div>
                                
                                <input type="hidden" 
                                       name="product[translations][{{ loop.index0 }}][language]" 
                                       value="{{ language.id }}">
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- Statuts -->
            <div class="card mb-4">
                <div class="card-header">
                    <h6 class="card-title mb-0">
                        <i class="fas fa-toggle-on me-2"></i>Statuts
                    </h6>
                </div>
                <div class="card-body">
                    {{ form_row(form.isActive, {
                        'attr': {'class': 'form-check-input'},
                        'label_attr': {'class': 'form-check-label'},
                        'label': 'Produit actif'
                    }) }}
                    <div class="form-text mb-3">Le produit sera visible sur le site</div>
                    
                    {{ form_row(form.isFeatured, {
                        'attr': {'class': 'form-check-input'},
                        'label_attr': {'class': 'form-check-label'},
                        'label': 'Mis en avant'
                    }) }}
                    <div class="form-text mb-3">Le produit apparaîtra en priorité</div>
                    
                    {{ form_row(form.isCustomizable, {
                        'attr': {'class': 'form-check-input'},
                        'label_attr': {'class': 'form-check-label'},
                        'label': 'Personnalisable'
                    }) }}
                    <div class="form-text">Le client pourra personnaliser ce produit</div>
                </div>
            </div>

            <!-- Options de garantie -->
            <div class="card mb-4">
                <div class="card-header">
                    <h6 class="card-title mb-0">
                        <i class="fas fa-shield-alt me-2"></i>Garanties
                    </h6>
                </div>
                <div class="card-body">
                    {{ form_row(form.energyClass, {
                        'attr': {'class': 'form-select'},
                        'label_attr': {'class': 'form-label fw-bold'}
                    }) }}
                    
                    <div class="row mt-3">
                        <div class="col-6">
                            {{ form_row(form.warrantyStructure, {
                                'attr': {'class': 'form-control', 'placeholder': '10'},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                        <div class="col-6">
                            {{ form_row(form.warrantyEquipment, {
                                'attr': {'class': 'form-control', 'placeholder': '5'},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Options disponibles -->
            <div class="card mb-4">
                <div class="card-header">
                    <h6 class="card-title mb-0">
                        <i class="fas fa-plus-circle me-2"></i>Options Disponibles
                    </h6>
                </div>
                <div class="card-body">
                    {{ form_row(form.availableOptions, {
                        'attr': {'class': 'form-select', 'size': '6'},
                        'label_attr': {'class': 'form-label fw-bold'}
                    }) }}
                    <div class="form-text">Sélectionnez les options qui peuvent être ajoutées à ce produit</div>
                </div>
            </div>

            <!-- Ordre d'affichage -->
            <div class="card mb-4">
                <div class="card-header">
                    <h6 class="card-title mb-0">
                        <i class="fas fa-sort me-2"></i>Affichage
                    </h6>
                </div>
                <div class="card-body">
                    {{ form_row(form.sortOrder, {
                        'attr': {'class': 'form-control', 'placeholder': '0'},
                        'label_attr': {'class': 'form-label fw-bold'}
                    }) }}
                    <div class="form-text">Ordre d'affichage dans les listes (0 = premier)</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Boutons d'action -->
    <div class="d-flex justify-content-between align-items-center mt-4">
        <a href="{{ path('admin_product_index') }}" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Retour à la liste
        </a>
        
        <div class="d-flex gap-2">
            {{ form_widget(form.save_and_continue) }}
            {{ form_widget(form.save) }}
        </div>
    </div>

    {{ form_end(form) }}
</div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Validation en temps réel du code produit
    const codeInput = document.querySelector('#product_code');
    if (codeInput) {
        codeInput.addEventListener('input', function() {
            // Vérifier que le code ne contient que des caractères autorisés
            const value = this.value;
            const validPattern = /^[A-Za-z0-9_-]*$/;
            
            if (!validPattern.test(value)) {
                this.classList.add('is-invalid');
            } else {
                this.classList.remove('is-invalid');
            }
        });
    }
    
    // Auto-génération du code basée sur la catégorie et le nom français
    const nameInputs = document.querySelectorAll('[name*="[name]"]');
    const categorySelect = document.querySelector('#product_category');
    
    nameInputs.forEach(input => {
        input.addEventListener('input', debounce(function() {
            generateProductCode();
        }, 500));
    });
    
    if (categorySelect) {
        categorySelect.addEventListener('change', generateProductCode);
    }
    
    function generateProductCode() {
        if (!codeInput || !nameInputs.length) return;
        
        // Si le code a déjà été modifié manuellement, ne pas le réécrire
        if (codeInput.dataset.modified === 'true') return;
        
        const frenchName = document.querySelector('[name*="[name]"]');
        const categoryCode = categorySelect?.selectedOptions[0]?.textContent?.match(/\((.*?)\)/)?.[1];
        
        if (frenchName && categoryCode) {
            const name = frenchName.value.trim();
            const category = categoryCode.trim();
            
            if (name && category) {
                const code = `${category}-${name}`.toLowerCase()
                    .replace(/[^a-z0-9]/g, '-')
                    .replace(/-+/g, '-')
                    .replace(/^-|-$/g, '');
                
                codeInput.value = code;
            }
        }
    }
    
    // Marquer le champ code comme modifié quand l'utilisateur tape
    codeInput?.addEventListener('input', function() {
        this.dataset.modified = 'true';
    });
    
    // Sauvegarde automatique
    let autoSaveTimeout;
    const form = document.querySelector('form');
    
    form?.addEventListener('input', function() {
        clearTimeout(autoSaveTimeout);
        autoSaveTimeout = setTimeout(function() {
            // Sauvegarde automatique locale (localStorage)
            saveDraft();
        }, 2000);
    });
    
    function saveDraft() {
        const formData = new FormData(form);
        const data = {};
        for (let [key, value] of formData.entries()) {
            data[key] = value;
        }
        localStorage.setItem('product_draft', JSON.stringify(data));
    }
    
    // Restaurer le brouillon au chargement
    const savedDraft = localStorage.getItem('product_draft');
    if (savedDraft && !codeInput.value) {
        try {
            const draft = JSON.parse(savedDraft);
            Object.keys(draft).forEach(key => {
                const input = form.querySelector(`[name="${key}"]`);
                if (input) {
                    input.value = draft[key];
                }
            });
        } catch (e) {
            console.log('Erreur lors de la restauration du brouillon:', e);
        }
    }
    
    // Effacer le brouillon après soumission réussie
    form?.addEventListener('submit', function() {
        localStorage.removeItem('product_draft');
    });
});

// Fonction de debounce pour optimiser les performances
function debounce(func, wait) {
    let timeout;
    return function executedFunction(...args) {
        const later = () => {
            clearTimeout(timeout);
            func(...args);
        };
        clearTimeout(timeout);
        timeout = setTimeout(later, wait);
    };
}
</script>
{% endblock %}