{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.product.new_page_title'|trans }} - MODUSCAP{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="{{ path('admin_product_index') }}">{{ 'admin.navigation.products'|trans }}</a>
                    </li>
                    <li class="breadcrumb-item active">{{ 'admin.common.new'|trans }}</li>
                </ol>
            </nav>
            <h1 class="h3 mb-1">{{ 'admin.product.new_title'|trans }}</h1>
            <p class="text-muted">{{ 'admin.product.new_description'|trans }}</p>
        </div>
    </div>

    {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': true}}) }}
    
    <div class="row">
        <div class="col-lg-8">
            <!-- Informations générales -->
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-info-circle me-2"></i>{{ 'admin.product.general_info'|trans }}
                    </h5>
                    <div class="form-check form-switch">
                        {{ form_widget(form.isActive, {
                            'attr': {'class': 'form-check-input'}
                        }) }}
                        <label class="form-check-label">{{ 'admin.product.active_product'|trans }}</label>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            {{ form_row(form.code, {
                                'attr': {'class': 'form-control form-control-lg', 'placeholder': ('admin.product.code_placeholder'|trans)},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.category, {
                                'attr': {'class': 'form-select'},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            {{ form_row(form.basePrice, {
                                'attr': {'class': 'form-control', 'placeholder': ('admin.product.price_placeholder'|trans)},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.surface, {
                                'attr': {'class': 'form-control', 'placeholder': ('admin.product.surface_placeholder'|trans)},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            {{ form_row(form.dimensions, {
                                'attr': {'class': 'form-control', 'placeholder': ('admin.product.dimensions_placeholder'|trans)},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.rooms, {
                                'attr': {'class': 'form-control', 'placeholder': ('admin.product.rooms_placeholder'|trans)},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            {{ form_row(form.height, {
                                'attr': {'class': 'form-control', 'placeholder': ('admin.product.height_placeholder'|trans)},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.assemblyTime, {
                                'attr': {'class': 'form-control', 'placeholder': ('admin.product.assembly_placeholder'|trans)},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Spécifications techniques -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-cogs me-2"></i>{{ 'admin.product.technical_specs'|trans }}
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-12">
                            {{ form_row(form.technicalSpecs, {
                                'attr': {'class': 'form-control', 'rows': 4, 'placeholder': ('admin.product.technical_specs_placeholder'|trans)},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Traductions multilingues -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-globe me-2"></i>{{ 'admin.product.multilingual_content'|trans }}
                        <small class="text-muted">{{ 'admin.product.add_multilingual_content'|trans }}</small>
                    </h5>
                </div>
                <div class="card-body">
                    <!-- Onglets des langues - Utilise les langues actives disponibles via l'extension Twig -->
                    {% set languages = get_languages() %}
                    
                    <ul class="nav nav-tabs" id="languageTabs" role="tablist">
                        {% for language in languages %}
                            <li class="nav-item" role="presentation">
                                <button class="nav-link {{ loop.first ? 'active' : '' }}" 
                                        id="lang-{{ language.code }}-tab" 
                                        data-bs-toggle="tab" 
                                        data-bs-target="#lang-{{ language.code }}" 
                                        type="button" role="tab">
                                    <span class="me-2">{{ language.flag }}</span>
                                    {{ language.name }}
                                </button>
                            </li>
                        {% endfor %}
                    </ul>
                    
                    <!-- Contenu des onglets -->
                    <div class="tab-content mt-3" id="languageTabsContent">
                        {% for language in languages %}
                            <div class="tab-pane fade {{ loop.first ? 'show active' : '' }}" 
                                 id="lang-{{ language.code }}" 
                                 role="tabpanel">
                                
                                <div class="row">
                                    <div class="col-12 mb-3">
                                        <label class="form-label fw-bold">{{ 'admin.product.product_name'|trans }}</label>
                                        <input type="text" 
                                               class="form-control form-control-lg" 
                                               name="product[translations][{{ loop.index0 }}][name]" 
                                               placeholder="{{ ('admin.product.product_name_placeholder'|trans)|replace({'%language%': language.name}) }}">
                                        <div class="form-text">
                                            {{ ('admin.product.name_display_info'|trans)|replace({'%language%': language.name}) }}
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="row">
                                    <div class="col-12 mb-3">
                                        <label class="form-label fw-bold">{{ 'admin.product.short_description'|trans }}</label>
                                        <input type="text" 
                                               class="form-control" 
                                               name="product[translations][{{ loop.index0 }}][shortDescription]" 
                                               placeholder="{{ 'admin.product.short_description_placeholder'|trans }}">
                                        <div class="form-text">
                                            {{ 'admin.product.short_description_info'|trans }}
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="row">
                                    <div class="col-12 mb-3">
                                        <label class="form-label fw-bold">{{ 'admin.product.complete_description'|trans }}</label>
                                        <textarea class="form-control" 
                                                  name="product[translations][{{ loop.index0 }}][description]" 
                                                  rows="5"
                                                  placeholder="{{ ('admin.product.description_placeholder'|trans)|replace({'%language%': language.name}) }}"></textarea>
                                        <div class="form-text">
                                            {{ 'admin.product.description_info'|trans }}
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">{{ 'admin.product.concept_design'|trans }}</label>
                                        <textarea class="form-control" 
                                                  name="product[translations][{{ loop.index0 }}][concept]" 
                                                  rows="3"
                                                  placeholder="{{ 'admin.product.concept_placeholder'|trans }}"></textarea>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">{{ 'admin.product.materials_detail'|trans }}</label>
                                        <textarea class="form-control" 
                                                  name="product[translations][{{ loop.index0 }}][materialsDetail]" 
                                                  rows="3"
                                                  placeholder="{{ 'admin.product.materials_detail_placeholder'|trans }}"></textarea>
                                    </div>
                                </div>
                                
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">{{ 'admin.product.equipment_detail'|trans }}</label>
                                        <textarea class="form-control" 
                                                  name="product[translations][{{ loop.index0 }}][equipmentDetail]" 
                                                  rows="3"
                                                  placeholder="{{ 'admin.product.equipment_detail_placeholder'|trans }}"></textarea>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">{{ 'admin.product.performance'|trans }}</label>
                                        <textarea class="form-control" 
                                                  name="product[translations][{{ loop.index0 }}][performanceDetails]" 
                                                  rows="3"
                                                  placeholder="{{ 'admin.product.performance_placeholder'|trans }}"></textarea>
                                    </div>
                                </div>
                                
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">{{ 'admin.product.specifications'|trans }}</label>
                                        <textarea class="form-control" 
                                                  name="product[translations][{{ loop.index0 }}][specifications]" 
                                                  rows="3"
                                                  placeholder="{{ 'admin.product.specs_placeholder'|trans }}"></textarea>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">{{ 'admin.product.advantages'|trans }}</label>
                                        <textarea class="form-control" 
                                                  name="product[translations][{{ loop.index0 }}][advantages]" 
                                                  rows="3"
                                                  placeholder="{{ 'admin.product.advantages_placeholder'|trans }}"></textarea>
                                    </div>
                                </div>
                                
                                <input type="hidden" 
                                       name="product[translations][{{ loop.index0 }}][language]" 
                                       value="{{ language.code }}">
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- Statuts avancés -->
            <div class="card mb-4">
                <div class="card-header">
                    <h6 class="card-title mb-0">
                        <i class="fas fa-toggle-on me-2"></i>{{ 'admin.product.advanced_statuses'|trans }}
                    </h6>
                </div>
                <div class="card-body">
                    <div class="form-check form-switch mb-3">
                        {{ form_widget(form.isFeatured, {
                            'attr': {'class': 'form-check-input'}
                        }) }}
                        <label class="form-check-label fw-bold">{{ 'admin.product.featured_product'|trans }}</label>
                        <div class="form-text">{{ 'admin.product.featured_product_info'|trans }}</div>
                    </div>
                    
                    <div class="form-check form-switch">
                        {{ form_widget(form.isCustomizable, {
                            'attr': {'class': 'form-check-input'}
                        }) }}
                        <label class="form-check-label fw-bold">{{ 'admin.product.customizable_product'|trans }}</label>
                        <div class="form-text">{{ 'admin.product.customizable_product_info'|trans }}</div>
                    </div>
                </div>
            </div>

            <!-- Options de garantie -->
            <div class="card mb-4">
                <div class="card-header">
                    <h6 class="card-title mb-0">
                        <i class="fas fa-shield-alt me-2"></i>{{ 'admin.product.warranty_performance'|trans }}
                    </h6>
                </div>
                <div class="card-body">
                    {{ form_row(form.energyClass, {
                        'attr': {'class': 'form-select'},
                        'label_attr': {'class': 'form-label fw-bold'}
                    }) }}
                    
                    <div class="row mt-3">
                        <div class="col-6">
                            {{ form_row(form.warrantyStructure, {
                                'attr': {'class': 'form-control', 'placeholder': ('admin.product.warranty_placeholder'|trans)},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                        <div class="col-6">
                            {{ form_row(form.warrantyEquipment, {
                                'attr': {'class': 'form-control', 'placeholder': ('admin.product.warranty_equipment_placeholder'|trans)},
                                'label_attr': {'class': 'form-label fw-bold'}
                            }) }}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Options disponibles -->
            <div class="card mb-4">
                <div class="card-header">
                    <h6 class="card-title mb-0">
                        <i class="fas fa-plus-circle me-2"></i>{{ 'admin.product.available_options'|trans }}
                        <small class="text-muted">({{ 'admin.common.multiple'|trans }})</small>
                    </h6>
                </div>
                <div class="card-body">
                    {{ form_row(form.availableOptions, {
                        'attr': {'class': 'form-select', 'size': '8'},
                        'label_attr': {'class': 'form-label fw-bold'}
                    }) }}
                    <div class="form-text">{{ 'admin.product.select_available_options_info'|trans }}</div>
                </div>
            </div>

            <!-- Ordre d'affichage -->
            <div class="card mb-4">
                <div class="card-header">
                    <h6 class="card-title mb-0">
                        <i class="fas fa-sort me-2"></i>{{ 'admin.product.display_order'|trans }}
                    </h6>
                </div>
                <div class="card-body">
                    {{ form_row(form.sortOrder, {
                        'attr': {'class': 'form-control', 'placeholder': ('admin.product.sort_order_placeholder'|trans)},
                        'label_attr': {'class': 'form-label fw-bold'}
                    }) }}
                    <div class="form-text">{{ 'admin.product.sort_order_info'|trans }}</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Boutons d'action -->
    <div class="d-flex justify-content-between align-items-center mt-4">
        <a href="{{ path('admin_product_index') }}" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>{{ 'admin.product.back_to_list'|trans }}
        </a>
        
        <div class="d-flex gap-2">
            {{ form_widget(form.save_and_continue) }}
            {{ form_widget(form.save) }}
        </div>
    </div>

    {{ form_end(form) }}
</div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Validation en temps réel du code produit
    const codeInput = document.querySelector('#product_code');
    if (codeInput) {
        codeInput.addEventListener('input', function() {
            const value = this.value;
            const validPattern = /^[A-Za-z0-9_-]*$/;
            
            if (!validPattern.test(value)) {
                this.classList.add('is-invalid');
            } else {
                this.classList.remove('is-invalid');
            }
        });
    }
    
    // Statistiques des traductions en temps réel
    updateTranslationStats();
    
    function updateTranslationStats() {
        const nameInputs = document.querySelectorAll('[name*="[name]"]');
        let filledCount = 0;
        let totalCount = nameInputs.length;
        
        nameInputs.forEach(input => {
            if (input.value.trim()) {
                filledCount++;
            }
        });
        
        // Afficher les stats dans la console
        console.log(`Traductions remplies: ${filledCount}/${totalCount}`);
    }
    
    // Écouter les changements dans les champs de traduction
    document.querySelectorAll('[name*="[name]"], [name*="[description]"]').forEach(input => {
        input.addEventListener('input', updateTranslationStats);
    });
    
    // Auto-génération du code basée sur la catégorie et le nom français
    const nameInputs = document.querySelectorAll('[name*="[name]"]');
    const categorySelect = document.querySelector('#product_category');
    
    nameInputs.forEach(input => {
        input.addEventListener('input', debounce(function() {
            generateProductCode();
        }, 500));
    });
    
    if (categorySelect) {
        categorySelect.addEventListener('change', generateProductCode);
    }
    
    function generateProductCode() {
        if (!codeInput || !nameInputs.length) return;
        
        // Si le code a déjà été modifié manuellement, ne pas le réécrire
        if (codeInput.dataset.modified === 'true') return;
        
        const frenchNameInput = document.querySelector('[name*="[language][fr]"][name*="[name]"]');
        if (frenchNameInput) {
            const categoryCode = categorySelect?.selectedOptions[0]?.textContent?.match(/\((.*?)\)/)?.[1];
            
            if (frenchNameInput && categoryCode) {
                const name = frenchNameInput.value.trim();
                const category = categoryCode.trim();
                
                if (name && category) {
                    const code = `${category}-${name}`.toLowerCase()
                        .replace(/[^a-z0-9]/g, '-')
                        .replace(/-+/g, '-')
                        .replace(/^-|-$/g, '');
                    
                    codeInput.value = code;
                }
            }
        }
    }
    
    // Marquer le champ code comme modifié quand l'utilisateur tape
    codeInput?.addEventListener('input', function() {
        this.dataset.modified = 'true';
    });
});

// Fonction de debounce pour optimiser les performances
function debounce(func, wait) {
    let timeout;
    return function executedFunction(...args) {
        const later = () => {
            clearTimeout(timeout);
            func(...args);
        };
        clearTimeout(timeout);
        timeout = setTimeout(later, wait);
    };
}
</script>
{% endblock %}